# List the available platform Talos cluster recipes.
default:
    @just --list

# Generate and encrypt a fresh Talos secrets bundle in the sibling secrets repo.
secrets-generate:
    uv run clusterctl.py generate-secrets

# Render Talos machine config outputs into .state/rendered/.
render:
    uv run clusterctl.py render

# Validate the rendered control-plane configuration with talosctl.
validate:
    uv run clusterctl.py validate

# Build a plain UEFI Talos ISO with the rendered config embedded.
iso-generate:
    uv run clusterctl.py generate-iso

# Bootstrap the control plane if the rendered node is not already bootstrapped.
bootstrap: render validate
    uv run scripts/bootstrap.py

# Download and merge the admin kubeconfig into the local kubectl config.
kubeconfig: render validate
    #!/usr/bin/env bash
    set -euo pipefail

    node_ip="$(yq -r '.addresses[]?.address' .state/rendered/controlplane.yaml | head -n1 | cut -d/ -f1)"
    if [[ -z "${node_ip}" ]]; then
        echo "error: failed to determine control-plane IP from .state/rendered/controlplane.yaml" >&2
        exit 1
    fi

    talosctl \
        --talosconfig .state/rendered/talosconfig \
        -e "${node_ip}" \
        -n "${node_ip}" \
        kubeconfig \
        --force-context-name platform \
        --force

# Apply the cluster-local Cilium LB IPAM and BGP resources to the live platform cluster.
cilium-bgp-apply:
    kubectl --context platform apply -f manifests/cilium-bgp-lb.yaml

# Expose the Argo CD server service through a Cilium-managed LoadBalancer IP.
argocd-server-lb-apply:
    kubectl --context platform patch service argocd-server -n argocd --type merge --patch-file manifests/argocd-server-loadbalancer-patch.yaml

# Show the assigned Argo CD LoadBalancer VIP and service status.
argocd-server-lb-status:
    kubectl --context platform get service argocd-server -n argocd -o wide

# Show Cilium BGP/LB resources on the platform cluster.
cilium-bgp-status:
    kubectl --context platform get CiliumLoadBalancerIPPool,CiliumBGPPeerConfig,CiliumBGPAdvertisement,CiliumBGPClusterConfig

# Show the advertised Argo CD service state and current LoadBalancer IP.
argocd-server-lb-vip:
    kubectl --context platform get service argocd-server -n argocd -o jsonpath='{.status.loadBalancer.ingress[0].ip}{"\n"}'

# Remove disposable rendered outputs and generated boot assets.
clean:
    rm -rf .state
